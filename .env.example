# Django Core
SECRET_KEY=replace-with-a-long-random-secret-key
# Prefer DJANGO_DEBUG; DEBUG is still supported for compatibility.
DJANGO_DEBUG=True
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TIME_ZONE=UTC

# Reverse proxy / HTTPS (set to True in production if behind a proxy)
USE_X_FORWARDED_HOST=False
USE_X_FORWARDED_PORT=False

# Security (production defaults are secure when DEBUG=False)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Database (choose one approach)
# 1) URL style (recommended on Render/Railway/Heroku)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# 2) Discrete values
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=brokerage_platform
# DB_USER=postgres
# DB_PASSWORD=replace-me
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Email (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=you@gmail.com
EMAIL_TIMEOUT=15

# Optional (already present in your local setup)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db
